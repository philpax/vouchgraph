{
  "lexicon": 1,
  "id": "dev.atvouch.graph.getEntireGraph",
  "defs": {
    "main": {
      "type": "query",
      "description": "Returns every vouch in the graph with cursor-based pagination.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["vouches", "total"],
          "properties": {
            "cursor": { "type": "string" },
            "total": { "type": "integer" },
            "vouches": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "dev.atvouch.graph.defs#vouchView"
              }
            }
          }
        }
      }
    }
  }
}
