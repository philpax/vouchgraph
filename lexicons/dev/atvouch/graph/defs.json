{
  "lexicon": 1,
  "id": "dev.atvouch.graph.defs",
  "defs": {
    "vouchView": {
      "type": "object",
      "required": ["uri", "creatorDid", "targetDid", "createdAt"],
      "properties": {
        "uri": { "type": "string", "format": "at-uri" },
        "creatorDid": { "type": "string", "format": "did" },
        "targetDid": { "type": "string", "format": "did" },
        "createdAt": { "type": "string", "format": "datetime" }
      }
    }
  }
}
